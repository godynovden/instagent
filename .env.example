# OpenAI API key (для генерации текстов/captions)
OPENAI_API_KEY=sk-...

# Google AI Studio API key (для Veo 2 видео-генерации)
# Получить: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Telegram Bot Token (для одобрения постов)
# Создать: https://t.me/BotFather -> /newbot
TELEGRAM_BOT_TOKEN=123456:ABC...

# Твой Telegram user ID (для получения уведомлений)
# Узнать: https://t.me/userinfobot
TELEGRAM_CHAT_ID=123456789

# Meta / Instagram Graph API
# Получить через: https://developers.facebook.com -> My Apps -> Instagram Basic Display
INSTAGRAM_ACCESS_TOKEN=EAABs...
INSTAGRAM_USER_ID=17841...

# Make.com webhook URL (публикация в Instagram через сценарий Make)
# Получить: Make.com → открыть сценарий → скопировать URL первого модуля Webhook
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/...

# OpenRouter (основной роутер для caption-моделей claude/gemini) — опционально
OPENROUTER_API_KEY=sk-or-v1-...

# Доп. провайдеры видео/изображений (опционально, generate_reel.py)
FAL_KEY=
HF_TOKEN=
LUMA_API_KEY=
RUNWAY_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# Пути
CONTENT_DIR=/root/Ecodisplays/content
OUTPUT_DIR=/root/Ecodisplays/output
